# ── GAS ERP Backend ──────────────────────────────────────────────────────────────
# URL del Web App en Google Apps Script (dominio bidcom.com.ar)
GAS_URL="https://script.google.com/a/macros/bidcom.com.ar/s/[DEPLOYMENT_ID]/exec"

# API Key generada con setupApiKey() en GAS
GAS_API_KEY=""

# ── Base de datos (Neon PostgreSQL) ──────────────────────────────────────────────
# Misma DB que Panel-Compras — comparte tablas de auth (User, Account, VerificationToken)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth v5 (Auth.js) ────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32   (o cualquier string aleatorio largo)
AUTH_SECRET=""

# ── Resend (magic links del login) ───────────────────────────────────────────────
# Misma API key que Panel-Compras
AUTH_RESEND_KEY="re_..."
AUTH_EMAIL_FROM="Bidcom Agro <onboarding@resend.dev>"
AUTH_TRUST_HOST="true"

# ── Emails adicionales permitidos (separados por coma) ───────────────────────────
# Por defecto solo acepta @bidcom.com.ar. Agregar acá emails externos si necesario.
ALLOWED_EMAILS=""
